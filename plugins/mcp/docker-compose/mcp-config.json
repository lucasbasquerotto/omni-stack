{
  "servers": [
    {
      "name": "docker_compose",
      "transport": "stdio",
      "command": "/app/target/release/mcp-server-docker-compose",
      "args": [],
      "timeout_secs": 310,
      "max_retries": 1,
      "allowed_tools": [
        "*"
      ],
      "env": {
        "WORKSPACE_DIR": "${WORKSPACE_DIR:-/opt/workspace}",
        "RUST_LOG": "info"
      }
    }
  ]
}