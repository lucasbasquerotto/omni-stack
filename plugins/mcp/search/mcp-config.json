{
  "servers": [
    {
      "name": "search",
      "transport": "stdio",
      "command": "/app/target/release/mcp-server-search",
      "args": [],
      "timeout_secs": 60,
      "max_retries": 2,
      "allowed_tools": [
        "*"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "DATA_DIR": "${DATA_DIR}",
        "RUST_LOG": "info"
      }
    }
  ]
}